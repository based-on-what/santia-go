# .env.example — copia este archivo como .env para desarrollo local
# El archivo .env NUNCA debe commitearse.

# Token público de Mapbox GL JS
# El prefijo "pk." indica que es un token de cliente (public key).
# Está diseñado para usarse en el navegador; no es un secreto.
# Configúralo en Netlify: Site Settings → Environment Variables
# (opcional si prefieres centralizar la gestión del token)
MAPBOX_PUBLIC_TOKEN=pk.eyJ1IjoiTVVfVVNVQVJJTyIsImEiOiJjTUlfVE9LRU5fQVFVSSJ9.EJEMPLO
